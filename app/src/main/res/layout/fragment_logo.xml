<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="100dp"
    android:background="?attr/colorPrimary"
   >


    <ImageView
        android:id="@+id/antenna_stem"
        android:layout_width="10dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginBottom="70dp"
        app:srcCompat="@drawable/antenna_stem"
        />

    <ImageView
        android:id="@+id/face"
        android:layout_width="170dp"
        android:layout_height="130dp"
        android:src="@drawable/face"
        android:layout_gravity="center"
        />

    <ImageView
        android:id="@+id/left_eye"
        android:layout_width="40dp"
        android:layout_height="50dp"
        android:layout_marginEnd="40dp"
        android:layout_gravity="center"
        app:srcCompat="@drawable/left_eye" />

    <ImageView
        android:id="@+id/right_eye"
        android:layout_width="40dp"
        android:layout_height="50dp"
        android:layout_marginStart="40dp"
        android:layout_gravity="center"
        app:srcCompat="@drawable/right_eye" />

    <ImageView
        android:id="@+id/antenna_cap"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginBottom="90dp"
        android:layout_gravity="center"
        app:srcCompat="@drawable/antenna_cap" />

    <TextView
        android:id="@+id/logo_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="30sp"
        tools:text="Flickr Droid" />

</FrameLayout>