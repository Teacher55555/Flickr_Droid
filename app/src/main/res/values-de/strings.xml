<resources>
    <string name="app_name">Flickr Droid</string>
    <string name="intro_version_1_10">Hallo! Der Frühling kommt und es ist Zeit, Ihre Logo-Kappe abzunehmen! 🙂\n\nWenn Sie einen Fehler finden, melden Sie ihn bitte ausführlich unter supflickrdroid@gmail.com\n\nUnd wenn Ihnen die App gefallen hat, unterstützen Sie sie bitte, indem Sie sie bewerten.\n\nDanke!</string>
    <string name="intro_header1">Hallo!</string>
    <string name="intro_description1">"Die Anwendung unterstützt zwei Betriebsarten mit und ohne Berechtigung"</string>
    <string name="intro_header2">Authorization</string>
    <string name="intro_description2">✓ Zugang zur persönlichen Seite\n✓ Kommentare hinzufügen / löschen\n✓ Favoritenfotos hinzufügen / löschen\n✓ Datenschutzkontrolle für Fotos</string>
    <string name="intro_header3">Hauptmenü</string>
    <string name="intro_description3">"Sie können sich jederzeit anmelden, indem Sie das Hauptmenü rechts verschieben"</string>
    <string name="intro_header4">Flexible Suche</string>
    <string name="intro_description4">1 - Beste Fotos des vergangenen Tages\n2 - beste Fotos für ein bestimmtes Datum\n3 - kürzlich hinzugefügte Fotos\n4 - Suche Fotos auf der Karte\n5 - Suche nach Fotos nach Kategorie</string>
    <string name="intro_header5">Suche auf der Karte</string>
    <string name="intro_description5">Ziehen Sie die Logo-Antenne nach oben, um das Einstellungsfeld herauszuziehen.\nBei Bedarf kann das Foto verschoben werden, indem Sie Ihren Finger darauf halten</string>
    <string name="intro_header6">Fotos anzeigen</string>
    <string name="intro_description6">"Ziehen Sie den Auslöser nach oben, um zusätzliche Informationen zum Foto anzuzeigen"</string>
    <string name="intro_header7">Fotoinformationen</string>
    <string name="intro_description7">"Klicken Sie auf die Markierung auf der Karte, um den Standort des Fotos in Google Maps anzuzeigen"</string>
    <string name="intro_header8">Link zu Flickr.com</string>
    <string name="intro_description8">"Durch Klicken auf ein Profilfoto (Gruppe, Album usw.) wird die aktuelle Seite basierend auf der aktiven Registerkarte auf Flickr.com im Browser geöffnet"</string>
    <string name="intro_header9">Fotodatenschutz</string>
    <string name="intro_description9">"Hier können Sie die Privatsphäre Ihrer Fotos ändern, indem Sie auf das entsprechende Symbol klicken."</string>
    <string name="intro_header10">Danke!</string>
    <string name="intro_description10">"Wenn Ihnen die App gefällt, unterstützen Sie sie bitte, indem Sie sie bewerten"</string>

