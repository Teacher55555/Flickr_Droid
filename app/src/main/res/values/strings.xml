<resources>
    <string name="app_name">Flickr Droid</string>

    <string name="intro_header1">Hello!</string>
    <string name="intro_description1">"The application supports 2 modes of operation, with and without authorization"</string>
    <string name="intro_header2">Authorization</string>
    <string name="intro_description2">✓ access to personal page\n✓ add / delete comments\n✓ add / delete favorites photos\n✓ photo privacy control</string>
    <string name="intro_header3">Main menu</string>
    <string name="intro_description3">"You can always log in by sliding the main menu on the right"</string>
    <string name="intro_header4">Flexible search</string>
    <string name="intro_description4">1 - Best photos of the past day\n2 - best photos for a specific date\n3 - recently added photos\n4 - search photos on the map\n5 - search photos by categories</string>
    <string name="intro_header5">Search on the map</string>
    <string name="intro_description5">Pull up on the logo antenna to slide out the settings panel.\nIf necessary, the photo can be moved by holding your finger on it</string>
    <string name="intro_header6">Viewing photos</string>
    <string name="intro_description6">"Pull the shutter up to see additional information about the photo"</string>
    <string name="intro_header7">Photo Information</string>
    <string name="intro_description7">"Click on the marker on the map to show the location of the photo in Google Maps"</string>
    <string name="intro_header8">Link to Flickr.com</string>
    <string name="intro_description8">"Clicking on a profile photo (group, album, etc.) will open the current page based on the active tab at Flickr.com in the browser"</string>
    <string name="intro_header9">Photo privacy</string>
    <string name="intro_description9">"Here you can change the privacy of your photos by clicking on the corresponding icon"</string>
    <string name="intro_header10">Thank you!</string>
    <string name="intro_description10">"If you like the app, please support it by rating it"</string>

