<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryDark">#FFFFFF</item>
        <item name="colorAccent">@color/colorBlueFlickr</item>
        <item name="actionBarTheme">@style/AppTheme.ToolbarWhite</item>
        <item name="titleTextColor">@color/colorGreyDark</item>
        <item name="subtitleTextColor">@color/colorDivideAndInactivWhiteTheme</item>
        <item name="tabTextColor">@color/colorPersonalPageLight</item>
        <item name="tabSelectedTextColor">@color/colorBlack</item>
        <item name="tabIconTint">@color/colorBlack</item>
        <item name="color">@color/colorLightGrey</item>
        <item name="colorSecondaryVariant">@color/colorRippleLightTheme</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowDisablePreview">false</item>
        <item name="android:scrollbarThumbVertical">@color/colorBlueFlickr</item>
        <item name="android:scrollbarSize">1dp</item>
        <item name="colorControlHighlight">@color/colorRippleLight</item>
    </style>

    <style name="WhiteMenuItem">
        <item name="tabTextColor">@color/colorWhite</item>
    </style>


    <style name="DarkMyTheme" parent="ThemeOverlay.AppCompat.DayNight">
        <item name="colorPrimary">#000000</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">@color/colorPinkFlickr</item>
        <item name="titleTextColor">@color/colorWhite</item>
        <item name="subtitleTextColor">@color/colorDivideAndInactivDarkTheme</item>
        <item name="tabTextColor">@color/colorPersonalPageDark</item>
        <item name="tabSelectedTextColor">@color/colorWhite</item>
        <item name="tabIconTint">@color/colorWhite</item>
        <item name="actionBarTheme">@style/AppTheme.ToolbarDark</item>
        <item name="color">@color/colorGreyDark</item>
        <item name="colorSecondaryVariant">@color/colorRippleDarkTheme</item>
        <item name="android:scrollbarThumbVertical">@color/colorPinkFlickr</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowDisablePreview">false</item>
        <item name="android:scrollbarSize">1dp</item>
        <item name="colorControlHighlight">@color/colorRippleDark</item>
    </style>


    <style name="DarkThemeActionBar" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorWhite</item>
        <item name="colorPrimaryDark">@color/colorWhite</item>
        <item name="colorAccent">@color/colorPinkFlickr</item>
        <item name="titleTextColor">@color/colorWhite</item>
        <item name="subtitleTextColor">@color/colorDivideAndInactivDarkTheme</item>
        <item name="tabTextColor">@color/colorGreyLight</item>
        <item name="tabSelectedTextColor">@color/colorWhite</item>
        <item name="tabIconTint">@color/colorWhite</item>
        <item name="actionBarTheme">@style/AppTheme.ToolbarDark</item>
        <item name="color">@color/colorWhite</item>
        <item name="colorSecondaryVariant">@color/colorRippleDarkTheme</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowDisablePreview">false</item>
    </style>


    <style name="AppTheme.Splash">
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="colorPrimary">@color/colorBlack</item>
    </style>

    <style name="AppTheme.WhiteAccent">
        <item name="colorAccent">@color/colorWhite</item>
    </style>

    <style name="TextAppearance.Design.My" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="textAllCaps">false</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="SwipeRefreshStyle">
        <item name="colorAccent">?attr/colorAccent</item>
    </style>

    <style name="SpinnerStyle" >
        <item name="android:textColorPrimary">?attr/colorAccent</item>
        <item name="android:textColorSecondary">@color/colorTransparent</item>
        <item name="android:textSize">20sp</item>

    </style>


    <style name="DialogPhotoPrivacyStyle">
        <item name="android:textColorSecondary">?attr/titleTextColor</item>
    </style>

    <style name="DialogAnimationStyle" >
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@drawable/date_dialog_background</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowAnimationStyle">@style/MyAnimation.Window</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:gravity">center</item>

        <item name="android:textColor">?attr/tabTextColor</item>    // SPINNER title + buttons
        <item name="textAllCaps">false</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="LoadingDialogAnimationStyle">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@drawable/date_dialog_background</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowAnimationStyle">@style/MyAnimation.Loading.Window</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:gravity">center</item>
    </style>


    <style name="ExpandedText.CollapsingToolBar" parent="TextAppearance.AppCompat.Display1">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">26sp</item>

    </style>

    <style name="MyAnimation.Window" parent="@android:style/Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/dialog_in_anim</item>
        <item name="android:windowExitAnimation">@anim/dialog_out_anim</item>
    </style>

    <style name="MyAnimation.Loading.Window" parent="@android:style/Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/loading_dialog_in_anim</item>
        <item name="android:windowExitAnimation">@anim/loading_dialog_out_anim</item>
    </style>

    <style name="AppTheme.ToolbarWhite">
        <item name="titleTextColor">@color/colorGreyDark</item>
        <item name="android:textCursorDrawable">@drawable/text_cursor</item>
    </style>

    <style name="AppTheme.ToolbarDark">
        <item name="titleTextColor">@color/colorWhite</item>
        <item name="android:textColorSecondary">@color/colorGreyLight</item>
        <item name="android:editTextColor">@color/colorWhite</item>
        <item name="android:textCursorDrawable">@drawable/text_cursor</item>
    </style>

    <style name="Text" />

    <style name="Text.Title.H4" parent="Text">
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Title.H5" parent="Text">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">8sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Title.H6" parent="Text">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Title.H7" parent="Text">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Subtitle">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.IntroDescription">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">2sp</item>
        <item name="android:textColor">?titleTextColor</item>
    </style>

    <style name="Text.Subtitle.Small">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">8sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Headline">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:textColor">?attr/titleTextColor</item>
    </style>

    <style name="Text.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="android:textColor">?attr/subtitleTextColor</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>